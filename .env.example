# Copy to .env and fill in your real API keys.

# OpenRouter (uses OpenAI-compatible API)
OPENROUTER_API_KEY=

# Optional: choose which provider your upcoming POC will use.
# For now this project targets: "openrouter"
LLM_PROVIDER=openrouter

# Optional override (defaults to OpenRouter chat completions endpoint)
OPENROUTER_BASE_URL=
