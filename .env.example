# Copy to .env and fill in your real API keys.
# NEVER commit .env with actual secrets to version control.

# =============================================================================
# Environment
# =============================================================================
ENVIRONMENT=development  # Options: development, production

# =============================================================================
# API Server
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000

# =============================================================================
# CORS (Cross-Origin Resource Sharing)
# =============================================================================
# Comma-separated list of allowed origins
# For development: http://localhost:3000,http://localhost:5173
# For production: https://your-domain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================================
# LLM Configuration (OpenRouter)
# =============================================================================
OPENROUTER_API_KEY=  # REQUIRED - Your OpenRouter API key

# Optional: choose which provider to use (default: openrouter)
LLM_PROVIDER=openrouter

# Optional override (defaults to OpenRouter chat completions endpoint)
OPENROUTER_BASE_URL=

# LLM Model configuration (default: deepseek/deepseek-v3.2)
# Available models: https://openrouter.ai/models
LLM_MODEL=deepseek/deepseek-v3.2

# =============================================================================
# Token Limits
# =============================================================================
MAX_INPUT_TOKENS=120000   # DeepSeek v3.2 has 128K context
MAX_OUTPUT_TOKENS=500

# =============================================================================
# YouTube API
# =============================================================================
YOUTUBE_TIMEOUT=30
YOUTUBE_MAX_RETRIES=3

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# =============================================================================
# Database (Sprint P3.2 - MySQL)
# =============================================================================
# MySQL database configuration for persistent storage
DB_HOST=localhost
DB_PORT=3306
DB_USER=yt_summerizer
DB_PASSWORD=  # Set your MySQL password here
DB_NAME=yt_summerizer

# =============================================================================
# JWT Authentication
# =============================================================================
JWT_SECRET_KEY=  # Generate a secure random key for production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
